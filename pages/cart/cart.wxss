.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 20rpx 20rpx 140rpx;
  box-sizing: border-box;
}

.empty {
  margin-top: 200rpx;
  text-align: center;
  color: #888;
  font-size: 28rpx;
}
.go {
  margin-top: 24rpx;
  color: #1677ff;
  display: inline-block;
}

.item {
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.check-wrap {
  margin-right: 10rpx;
  padding-top: 50rpx;
}

.cover {
  width: 150rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background: #eee;
  margin-right: 16rpx;
}

.info {
  flex: 1;
}

.name {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
}
.author {
  margin-top: 8rpx;
  color: #666;
  font-size: 24rpx;
}
.price {
  margin-top: 10rpx;
  color: #e64340;
  font-size: 30rpx;
  font-weight: 700;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.count-box {
  display: flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  overflow: hidden;
}
.btn {
  width: 50rpx;
  text-align: center;
  padding: 6rpx 0;
  background: #fafafa;
}
.count {
  width: 60rpx;
  text-align: center;
}
.remove {
  color: #999;
  font-size: 24rpx;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.all-check {
  display: flex;
  align-items: center;
  color: #333;
  font-size: 26rpx;
}

.sum {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
}
.money {
  color: #e64340;
  font-size: 34rpx;
  font-weight: 700;
}

.checkout {
  background: #1677ff;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
}
