.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.count {
  font-size: 24rpx;
  color: #888;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.book-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.cover {
  width: 150rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: #eee;
  flex-shrink: 0;
}

.info {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex: 1;
}

.name {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
  line-height: 1.4;
}

.author {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.price-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.price {
  color: #e64340;
  font-size: 30rpx;
  font-weight: 700;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.tag.new {
  color: #1aad19;
  background: #e8f8e8;
}

.tag.hot {
  color: #ff8f1f;
  background: #fff3e6;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
