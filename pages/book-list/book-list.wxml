<view class="page">
  <view class="header">
    <text class="title">{{categoryName}}</text>
    <text class="count">共 {{bookList.length}} 本</text>
  </view>

  <view wx:if="{{bookList.length > 0}}" class="list">
    <view
      class="book-item"
      wx:for="{{bookList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <image class="cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{item.name}}</view>
        <view class="author">作者：{{item.author}}</view>
        <view class="price-row">
          <text class="price">¥{{item.price}}</text>
          <text wx:if="{{item.isNew}}" class="tag new">新书</text>
          <text wx:if="{{item.isHot}}" class="tag hot">热门</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <text>该分类下暂无图书</text>
  </view>
</view>