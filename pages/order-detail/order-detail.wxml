<view class="page" wx:if="{{order}}">
  <!-- 订单状态头部 -->
  <view class="status-header status-{{order.status}}">
    <view class="status-icon">
      <text wx:if="{{order.status === 'PAID'}}">✓</text>
      <text wx:if="{{order.status === 'PENDING'}}">⏱</text>
      <text wx:if="{{order.status === 'CANCELED'}}">✕</text>
      <text wx:if="{{order.status === 'SHIPPED'}}">🚚</text>
      <text wx:if="{{order.status === 'COMPLETED'}}">🎉</text>
    </view>
    <view class="status-info">
      <view class="status-title">{{order.statusText}}</view>
      <view class="status-desc">
        <text wx:if="{{order.status === 'PENDING'}}">请在30分钟内完成支付</text>
        <text wx:if="{{order.status === 'PAID'}}">感谢您的购买，商品即将发货</text>
        <text wx:if="{{order.status === 'CANCELED'}}">该订单已取消</text>
        <text wx:if="{{order.status === 'SHIPPED'}}">商品已发出，请注意查收</text>
        <text wx:if="{{order.status === 'COMPLETED'}}">感谢您的购买，期待再次光临</text>
      </view>
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="section address-section" wx:if="{{order.address}}">
    <view class="section-title">收货信息</view>
    <view class="address-info">
      <view class="receiver">
        <text class="name">{{order.address.name}}</text>
        <text class="phone">{{order.address.phone}}</text>
      </view>
      <view class="detail">{{order.address.fullAddress || order.address.detail}}</view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="section order-info-section">
    <view class="section-title">订单信息</view>
    <view class="info-item">
      <text class="label">订单编号</text>
      <text class="value">{{order.id}}</text>
    </view>
    <view class="info-item">
      <text class="label">下单时间</text>
      <text class="value">{{order.createTimeText}}</text>
    </view>
    <view class="info-item" wx:if="{{order.remark}}">
      <text class="label">备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section goods-section">
    <view class="section-title">商品信息</view>
    <block wx:for="{{order.items}}" wx:key="id">
      <view
        class="goods-item"
        bindtap="goBookDetail"
        data-id="{{item.id}}"
      >
        <image class="goods-cover" src="{{item.cover}}" mode="aspectFit"></image>
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-price">¥{{Number(item.price).toFixed(2)}}</view>
          <view class="goods-count">x{{item.count}}</view>
        </view>
      </view>
    </block>
  </view>

  <!-- 金额汇总 -->
  <view class="section price-section">
    <view class="price-item">
      <text class="label">商品总价</text>
      <text class="value">¥{{order.totalPriceText}}</text>
    </view>
    <view class="price-item">
      <text class="label">运费</text>
      <text class="value">¥0.00</text>
    </view>
    <view class="price-item total">
      <text class="label">实付款</text>
      <text class="value">¥{{order.totalPriceText}}</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions" wx:if="{{order.status === 'PENDING'}}">
    <button class="action-btn cancel" bindtap="onCancelOrder">取消订单</button>
    <button class="action-btn pay" bindtap="onPayOrder">立即支付</button>
  </view>
  <view class="bottom-actions" wx:if="{{order.status === 'PAID'}}">
    <button class="action-btn again" open-type="switchTab" url="/pages/home/home">继续购物</button>
    <button class="action-btn ship" bindtap="onShipOrder">模拟发货</button>
  </view>
  <view class="bottom-actions" wx:if="{{order.status === 'SHIPPED'}}">
    <button class="action-btn again" open-type="switchTab" url="/pages/home/home">继续购物</button>
    <button class="action-btn confirm" bindtap="onCompleteOrder">确认收货</button>
  </view>
  <view class="bottom-actions" wx:if="{{order.status === 'COMPLETED'}}">
    <button class="action-btn again" open-type="switchTab" url="/pages/home/home">继续购物</button>
  </view>
</view>
