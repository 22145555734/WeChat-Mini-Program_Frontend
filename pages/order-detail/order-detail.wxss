.page {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding-bottom: 120rpx;
}

/* 状态头部 */
.status-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  color: #fff;
}

.status-PENDING {
  background: linear-gradient(135deg, #ff9800 0%, #ffb74d 100%);
}

.status-PAID {
  background: linear-gradient(135deg, #4caf50 0%, #81c784 100%);
}

.status-CANCELED {
  background: linear-gradient(135deg, #9e9e9e 0%, #bdbdbd 100%);
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.status-info {
  flex: 1;
}

.status-title {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 地址信息 */
.address-info {
  padding: 10rpx 0;
}

.receiver {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.receiver .name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-right: 24rpx;
}

.receiver .phone {
  font-size: 28rpx;
  color: #666;
}

.address-info .detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 订单信息 */
.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  color: #999;
}

.info-item .value {
  color: #333;
}

/* 商品列表 */
.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-price {
  font-size: 26rpx;
  color: #ff4d4f;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
  align-self: flex-end;
}

/* 价格汇总 */
.price-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.price-item .label {
  color: #666;
}

.price-item .value {
  color: #333;
}

.price-item.total {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.price-item.total .label {
  color: #333;
  font-weight: 500;
}

.price-item.total .value {
  color: #ff4d4f;
  font-weight: 500;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.action-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.action-btn.pay {
  background: #ff4d4f;
  color: #fff;
}

.action-btn.again {
  background: #2b7cff;
  color: #fff;
}
