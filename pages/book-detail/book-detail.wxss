.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.cover {
  width: 100%;
  height: 420rpx;
  border-radius: 12rpx;
  background: #eee;
}

.content {
  margin-top: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.author {
  margin-top: 10rpx;
  color: #666;
  font-size: 26rpx;
}

.tags {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.tag.new {
  color: #1aad19;
  background: #e8f8e8;
}

.tag.hot {
  color: #ff8f1f;
  background: #fff3e6;
}

.tag.cate {
  color: #576b95;
  background: #eef3ff;
}

.price {
  margin-top: 20rpx;
  color: #e64340;
  font-size: 40rpx;
  font-weight: 700;
}

.desc-title {
  margin-top: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.desc {
  margin-top: 12rpx;
  color: #555;
  line-height: 1.8;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
}

.cart {
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.buy {
  background: #1677ff;
  color: #fff;
}
