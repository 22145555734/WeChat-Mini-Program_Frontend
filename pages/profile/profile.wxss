.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #2b7cff 0%, #1677ff 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: 500;
}

.user-info {
  flex: 1;
}

.nickname {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tips {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section:last-of-type {
  margin-top: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more {
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.arrow {
  font-size: 24rpx;
}

/* 订单标签 */
.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.order-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-icon.pending {
  background: #fff5f5;
}

.order-icon.paid {
  background: #f6ffed;
}

.order-icon.all {
  background: #f0f5ff;
}

.iconfont {
  font-size: 36rpx;
}

.order-label {
  font-size: 26rpx;
  color: #666;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #fa5151;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

/* 功能菜单 */
.menu-list {
  margin: -10rpx -30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.version {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 60rpx;
}
