<view class="page">
  <block wx:if="{{orders.length}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="card">
        <view class="head">
          <text class="no">订单号：{{item.id}}</text>
          <text class="status">{{item.statusText}}</text>
        </view>

        <view class="time">下单时间：{{item.createTimeText}}</view>

        <view class="goods-preview">
          <block wx:for="{{item.items}}" wx:key="id">
            <image class="cover" src="{{item.cover}}" mode="aspectFill"></image>
          </block>
        </view>

        <view class="foot">
          <text>共 {{item.totalCount}} 件</text>
          <text class="price">合计：¥{{item.totalPriceText}}</text>
        </view>
      </view>
    </block>
  </block>

  <view class="empty" wx:else>
    <view class="empty-text">暂无订单</view>
    <button type="primary" size="mini" bindtap="goShopping">去逛逛</button>
  </view>
</view>