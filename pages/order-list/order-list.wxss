.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.no {
  font-size: 26rpx;
  color: #333;
}

.status {
  font-size: 24rpx;
  color: #fa5151;
}
.status-PENDING {
  color: #fa5151;
}
.status-PAID {
  color: #52c41a;
}
.status-CANCELED {
  color: #999;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 14rpx;
}

.goods-preview {
  display: flex;
  gap: 12rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.cover {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.foot {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
}

.price {
  color: #111;
  font-weight: 600;
}

.empty {
  height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.action-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  line-height: 1.2;
}
.action-btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.action-btn.pay {
  background: #1677ff;
  color: #fff;
}
