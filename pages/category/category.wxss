.page {
  height: 100vh;
  background: #f7f8fa;
}

.content {
  display: flex;
  height: 100%;
}

/* 左侧分类列表 */
.category-sidebar {
  width: 180rpx;
  background: #f5f5f5;
  height: 100%;
}

.category-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border-left: 4rpx solid transparent;
}

.category-item.active {
  background: #fff;
  color: #1677ff;
  border-left-color: #1677ff;
  font-weight: 500;
}

/* 右侧图书列表 */
.book-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  height: 100%;
}

.book-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
}

.cover {
  width: 160rpx;
  height: 220rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.author {
  font-size: 26rpx;
  color: #999;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.price {
  font-size: 32rpx;
  color: #fa5151;
  font-weight: 600;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag.new {
  background: #e6f7ff;
  color: #1890ff;
}

.tag.hot {
  background: #fff7e6;
  color: #fa8c16;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
