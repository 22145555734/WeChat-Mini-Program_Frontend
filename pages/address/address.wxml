<view class="page">
  <!-- 地址列表 -->
  <block wx:if="{{!editing}}">
    <block wx:if="{{addresses.length}}">
      <block wx:for="{{addresses}}" wx:key="id">
        <view class="address-item" bindtap="onSelectAddress" data-item="{{item}}">
          <view class="address-header">
            <text class="name">{{item.name}}</text>
            <text class="phone">{{item.phone}}</text>
            <view class="tags">
              <text class="tag default-tag" wx:if="{{item.isDefault}}">默认</text>
            </view>
          </view>
          <view class="address-detail">{{item.fullAddress || item.detail}}</view>
          <view class="address-actions">
            <button class="action-btn" catchtap="onSetDefault" data-id="{{item.id}}" disabled="{{item.isDefault}}">
              {{item.isDefault ? '已设默认' : '设为默认'}}
            </button>
            <button class="action-btn" catchtap="onEdit" data-item="{{item}}">编辑</button>
            <button class="action-btn delete" catchtap="onDelete" data-id="{{item.id}}">删除</button>
          </view>
        </view>
      </block>
    </block>
    <view class="empty" wx:else>
      <text>暂无收货地址</text>
    </view>

    <button class="add-btn" bindtap="onAdd">+ 新增地址</button>
  </block>

  <!-- 编辑/新增表单 -->
  <block wx:else>
    <view class="form">
      <view class="form-item">
        <text class="label">收货人</text>
        <input class="input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onInputChange" data-field="name" />
      </view>
      <view class="form-item">
        <text class="label">手机号</text>
        <input class="input" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInputChange" data-field="phone" type="number" maxlength="11" />
      </view>
      <view class="form-item">
        <text class="label">所在地区</text>
        <picker mode="region" bindchange="onRegionChange" value="{{region}}">
          <view class="picker">
            <text wx:if="{{region[0]}}">{{region[0]}} {{region[1]}} {{region[2]}}</text>
            <text class="placeholder" wx:else>请选择省市区</text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">详细地址</text>
        <textarea class="input textarea" placeholder="街道、门牌号等" value="{{form.detail}}" bindinput="onInputChange" data-field="detail" auto-height />
      </view>
    </view>

    <view class="form-actions">
      <button class="cancel-btn" bindtap="onCancelEdit">取消</button>
      <button class="save-btn" bindtap="onSave">保存</button>
    </view>
  </block>
</view>